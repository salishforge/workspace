{
  "name": "@salishforge/hyphae-agents",
  "version": "1.0.0",
  "description": "Hyphae agent implementations (Flint + Clio) with CrewAI and AutoGen",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev:flint": "HYPHAE_URL=http://localhost:3100 AGENT_ENDPOINT=http://localhost:3050 PORT=3050 ts-node flint-crewai.ts",
    "dev:clio": "HYPHAE_URL=http://localhost:3100 AGENT_ENDPOINT=http://localhost:3051 PORT=3051 ts-node clio-autogen.ts",
    "start:flint": "node dist/flint-crewai.js",
    "start:clio": "node dist/clio-autogen.js",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.4.0",
    "uuid": "^9.0.0",
    "@google/generative-ai": "^0.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "typescript": "^5.1.0",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
